# ── Backend (server/) ─────────────────────────────────────────────────────
# Required: Fireworks AI API key (get from app.fireworks.ai/account/api-keys)
FIREWORKS_API_KEY=fw_...

# Optional: custom port for Express backend (default: 3001)
PORT=3001

# ── Frontend (src/) ──────────────────────────────────────────────────────
# Optional: WalletConnect project ID (get from cloud.walletconnect.com)
# Without this, only injected wallets (MetaMask) will work
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Optional frontend API base URL for Four.meme
# Use /meme-api/v1 if you want the Vite dev proxy to forward to https://four.meme
# Otherwise the default is https://four.meme/meme-api/v1
# VITE_FOUR_MEME_API_BASE_URL=/meme-api/v1

# ── Models used ───────────────────────────────────────────────────────────
# LLM   : accounts/fireworks/models/deepseek-v3p2
# Image : accounts/fireworks/models/flux-1-dev-fp8
