# ── Backend (server/) ─────────────────────────────────────────────────────
# Provider Selection: "fireworks" or "dgrid"
AI_LLM_PROVIDER=dgrid
AI_IMAGE_PROVIDER=fireworks

# ── Fireworks AI ──────────────────────────────────────────────────────────
# Get your API key from: https://app.fireworks.ai/account/api-keys
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_LLM_MODEL=accounts/fireworks/models/kimi-k2-instruct-0905
FIREWORKS_IMAGE_MODEL=accounts/fireworks/models/flux-1-dev-fp8

# ── DGrid AI ─────────────────────────────────────────────────────────────
# Get your API key from DGrid dashboard
DGRID_API_KEY=your_dgrid_api_key_here
DGRID_LLM_MODEL=anthropic/claude-haiku-4.5
DGRID_IMAGE_MODEL=google/gemini-3-pro-image-preview
